# PRIMARY launcher: PotatoCurvePad (bonding curve). All NEW launches go here.
# Leave unset for a "not deployed" / can't-launch UI state.
NEXT_PUBLIC_CURVE_PAD_ADDRESS_BASE_SEPOLIA=
NEXT_PUBLIC_CURVE_PAD_ADDRESS_LOCALHOST=
NEXT_PUBLIC_CURVE_PAD_ADDRESS_ROBINHOOD=0x94085E08B91dA3cB974c14FE6d51B20a014b6069

# LEGACY direct-to-Uniswap PotatoPad. Read-only now — no new launches, but its
# existing tokens still resolve, display, and trade. Keep set so they don't vanish.
NEXT_PUBLIC_PAD_ADDRESS_BASE_SEPOLIA=
NEXT_PUBLIC_PAD_ADDRESS_LOCALHOST=
NEXT_PUBLIC_PAD_ADDRESS_ROBINHOOD=0x88bb90A984B4f61d971d71b25c81b187AEE4Ca07

# WETH on the local Hardhat node (Base Sepolia WETH is hardcoded)
NEXT_PUBLIC_WETH_ADDRESS_LOCALHOST=

# WalletConnect Cloud project id (optional; demo placeholder used otherwise)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Used to switch from Dev env to Prod env
NODE_ENV="production"

# Gemini image generation (server-only) for /api/generate-art
GEMINI_API_KEY=

# Google Analytics (GA4) measurement id (public in-browser by design; kept out of source)
NEXT_PUBLIC_GA_ID=

# Postgres SESSION-mode pooler URL (Supabase: Project Settings > Database >
# Connection string > URI > "Session pooler"). Used only by scripts/migrate.mjs,
# which runs automatically on `npm start` and applies supabase/migrations/*.sql.
# MUST be the session pooler (port 5432), not the transaction pooler (6543):
# pgbouncer drops session state, which breaks advisory locks and multi-statement DDL.
DIRECT_URL=
