# PotatoPad contract addresses (leave unset for a "not deployed" UI state)
NEXT_PUBLIC_PAD_ADDRESS_BASE_SEPOLIA=
NEXT_PUBLIC_PAD_ADDRESS_LOCALHOST=
NEXT_PUBLIC_PAD_ADDRESS_ROBINHOOD=0x12A075A946c790F05a23d2DcEa70B207DB23D91F

# WETH on the local Hardhat node (Base Sepolia WETH is hardcoded)
NEXT_PUBLIC_WETH_ADDRESS_LOCALHOST=

# WalletConnect Cloud project id (optional; demo placeholder used otherwise)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Used to switch from Dev env to Prod env
NODE_ENV="production"

# Gemini image generation (server-only) for /api/generate-art
GEMINI_API_KEY=
