# Postgres connection — Ponder stores indexed data here. If unset, Ponder falls
# back to an in-memory PGlite database (fine for local dev, not production).
DATABASE_URL=postgresql://user:password@localhost:5432/potatopad

# Robinhood Chain RPC. The public endpoint works, but a dedicated key (e.g.
# Alchemy) is strongly recommended for backfill throughput.
PONDER_RPC_URL_4663=https://rpc.mainnet.chain.robinhood.com

# Optional overrides — defaults match the live deployment in web/lib/config.ts.
# PONDER_CHAIN_ID=4663
# PONDER_PAD_ADDRESSES=0x12A075A946c790F05a23d2DcEa70B207DB23D91F,0xc12723c251dABcBe10c4F44060A6AE6b5E96a79d
# PONDER_START_BLOCK=11481181
